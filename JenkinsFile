pipeline {
    agent any

    parameters {
        string(
            name: 'GIT_REPO_URL',
            defaultValue: 'https://github.com/VinothShanmugam01-Cgw/deployment.git',
            description: 'Git Repository URL'
        
        string(
            name: 'GIT_BRANCH',
            defaultValue: 'main',
            description: 'Git Branch'
        
        string(
            name: 'DOCKER_IMAGE_NAME',
            defaultValue: 'dockerhub-user/app',
            description: 'Docker Image Name'
        
        string(
            name: 'SONAR_PROJECT_KEY',
            defaultValue: 'learning-k8s',
            description: 'SonarQube Project Key'
        
        string(
            name: 'K8S_API_SERVER',
            defaultValue: 'https://192.168.7.27:6443',
            description: 'Kubernetes API Server URL'
        
        string(
            name: 'RECIPIENT_EMAIL',
            defaultValue: 'devops-team@example.com',
            description: 'Notification Email'
        
        choice(
            name: 'DEPLOYMENT_STRATEGY',
            choices: [
                'Continuous Deployment',
                'Continuous Delivery'
            ],
            description: 'Deployment Strategy'
        
    )

    environment {
        SONAR_HOME            = tool 'sonar-scanner'
        DOCKER_TAG            = "${BUILD_NUMBER}"
        DOCKER_CREDENTIALS_ID = 'dockerhub-credentials'
        SONAR_TOKEN           = credentials('sonar-token')
        K8S_SA_TOKEN          = credentials('k8s-sa-token')
        K8S_NAMESPACE         = 'learning-k8s'
    }

    stages {

        stage('Checkout') {
            steps {
                git(
                    branch: params.GIT_BRANCH,
                    credentialsId: 'github-credentials',
                    url: params.GIT_REPO_URL
                
            }
        }

        stage('Trivy File Scan') {
            steps {
                bat """
                trivy fs ^
                  --severity HIGH,CRITICAL ^
                  --exit-code 0 ^
                  --output trivy-fs-report.txt ^
                  .
                """
            }
        }

        stage('Start SonarQube Container') {
            steps {
                bat 'docker rm -f sonarqube || exit 0'

                bat '''
                docker run -d ^
                  --name sonarqube ^
                  -p 9000:9000 ^
                  -v sonarqube_data:/opt/sonarqube/data ^
                  sonarqube:community
                '''

                bat '''
                @echo off
                echo Waiting for SonarQube to be fully ready...
                :loop
                ping -n 16 127.0.0.1 > nul
                curl.exe -s http://localhost:9000/api/system/status > status.txt
                findstr /C:"\"UP\"" status.txt > nul
                if %ERRORLEVEL%==0 goto ready
                echo Not ready yet, retrying...
                goto loop
                :ready
                echo SonarQube is UP and ready!
                ping -n 31 127.0.0.1 > nul
                echo Proceeding with analysis...
                del status.txt
                '''
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonar-server') {
                    bat """
                    %SONAR_HOME%\\bin\\sonar-scanner.bat ^
                      -Dsonar.projectKey=${params.SONAR_PROJECT_KEY} ^
                      -Dsonar.projectName=learning-k8s ^
                      -Dsonar.sources=.
                    """
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Stop SonarQube Container') {
            steps {
                bat 'docker rm -f sonarqube || exit 0'
            }
        }

        stage('Docker Build') {
            steps {
                bat """
                docker build ^
                  -t ${params.DOCKER_IMAGE_NAME}:${DOCKER_TAG} .
                """

                bat """
                docker tag ^
                  ${params.DOCKER_IMAGE_NAME}:${DOCKER_TAG} ^
                  ${params.DOCKER_IMAGE_NAME}:latest
                """
            }
        }

        stage('Trivy Image Scan') {
            steps {
                bat """
                trivy image ^
                  --severity HIGH,CRITICAL ^
                  --exit-code 0 ^
                  --output trivy-image-report.txt ^
                  ${params.DOCKER_IMAGE_NAME}:${DOCKER_TAG}
                """
            }
        }

        stage('Push Image') {
            steps {
                withDockerRegistry(
                    credentialsId: "${DOCKER_CREDENTIALS_ID}",
                    url: 'https://index.docker.io/v1/'
                 {
                    bat """
                    docker push ${params.DOCKER_IMAGE_NAME}:${DOCKER_TAG}
                    docker push ${params.DOCKER_IMAGE_NAME}:latest
                    """
                }
            }
        }

        stage('Approval') {
            when {
                expression {
                    params.DEPLOYMENT_STRATEGY == 'Continuous Delivery'
                }
            }
            steps {
                timeout(time: 30, unit: 'MINUTES') {
                    input(
                        message: "Build #${BUILD_NUMBER} is ready. Proceed to Deployment?",
                        ok: "Proceed to Deployment"
                    
                }
            }
        }

        stage('Deploy To Kubernetes') {
            steps {
                bat """
                copy k8s\\deployment.yaml deployment.yaml

                powershell -Command "(Get-Content deployment.yaml) -replace 'IMAGE_PLACEHOLDER', '${params.DOCKER_IMAGE_NAME}:${DOCKER_TAG}' | Set-Content deployment.yaml"

                kubectl apply ^
                  --server=${params.K8S_API_SERVER} ^
                  --token=%K8S_SA_TOKEN% ^
                  --insecure-skip-tls-verify=true ^
                  -f k8s\\service.yaml

                kubectl apply ^
                  --server=${params.K8S_API_SERVER} ^
                  --token=%K8S_SA_TOKEN% ^
                  --insecure-skip-tls-verify=true ^
                  -f deployment.yaml

                kubectl rollout status ^
                  deployment/learning-k8s-deployment ^
                  -n %K8S_NAMESPACE% ^
                  --server=${params.K8S_API_SERVER} ^
                  --token=%K8S_SA_TOKEN% ^
                  --insecure-skip-tls-verify=true ^
                  --timeout=300s
                """
            }
        }

        stage('Verify Deployment') {
            steps {
                bat """
                kubectl get pods ^
                  -n %K8S_NAMESPACE% ^
                  --server=${params.K8S_API_SERVER} ^
                  --token=%K8S_SA_TOKEN% ^
                  --insecure-skip-tls-verify=true

                kubectl get svc ^
                  -n %K8S_NAMESPACE% ^
                  --server=${params.K8S_API_SERVER} ^
                  --token=%K8S_SA_TOKEN% ^
                  --insecure-skip-tls-verify=true
                """
            }
        }
    }

    post {

        success {
            emailext(
                subject: "SUCCESS - Build #${BUILD_NUMBER}",
                body: """
Application deployed successfully.

Build Number  : ${BUILD_NUMBER}
Image         : ${params.DOCKER_IMAGE_NAME}:${DOCKER_TAG}
Namespace     : ${K8S_NAMESPACE}
K8S API Server: ${params.K8S_API_SERVER}

Build URL:
${BUILD_URL}
""",
                to: "${params.RECIPIENT_EMAIL}"
            
        }

        failure {
            emailext(
                subject: "FAILED - Build #${BUILD_NUMBER}",
                body: """
Build failed.

Build Number  : ${BUILD_NUMBER}
K8S API Server: ${params.K8S_API_SERVER}

Check:
${BUILD_URL}
""",
                to: "${params.RECIPIENT_EMAIL}"
            
        }

        always {
            bat 'docker rm -f sonarqube || exit 0'
            bat "docker rmi ${params.DOCKER_IMAGE_NAME}:${DOCKER_TAG} || exit 0"
            cleanWs()
        }
    }
}