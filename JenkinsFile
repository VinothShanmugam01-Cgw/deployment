pipeline {
    agent any

    parameters {
        string(
            name: 'GIT_REPO_URL',
            defaultValue: 'https://github.com/your-org/your-repo.git',
            description: 'GitHub repository URL'
        )
        string(
            name: 'GIT_BRANCH',
            defaultValue: 'main',
            description: 'Branch to build and deploy'
        )
        string(
            name: 'K8S_NAMESPACE',
            defaultValue: 'production',
            description: 'Kubernetes namespace to deploy into'
        )
        string(
            name: 'RECIPIENT_EMAIL',
            defaultValue: 'devops-team@your-org.com',
            description: 'Email address for build notifications'
        )
        string(
            name: 'DOCKER_IMAGE_NAME',
            defaultValue: 'your-dockerhub-username/your-app-name',
            description: 'Docker Hub image name (username/repo)'
        )
        string(
            name: 'APP_NAME',
            defaultValue: 'your-app',
            description: 'Application name (used for K8s deployment name and labels)'
        )
        string(
            name: 'SONAR_PROJECT_KEY',
            defaultValue: 'your-project-key',
            description: 'SonarQube project key'
        )
        string(
            name: 'K8S_API_SERVER',
            defaultValue: 'https://your-k8s-api-server:6443',
            description: 'On-prem Kubernetes API server URL'
        )
    }

    environment {
        SONAR_HOME            = tool 'sonar-scanner'
        DOCKER_TAG            = "${BUILD_NUMBER}"
        DOCKER_CREDENTIALS_ID = 'dockerhub-credentials'
        SONAR_TOKEN           = credentials('sonar-token')
        K8S_SA_TOKEN          = credentials('k8s-sa-token')
        K8S_DEPLOYMENT_FILE   = 'k8s/deployment.yaml'
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: "${params.GIT_BRANCH}",
                    credentialsId: 'github-credentials',
                    url: "${params.GIT_REPO_URL}"
            }
        }

        stage('Trivy FS Scan') {
            steps {
                sh """
                    trivy fs \
                        --format table \
                        --exit-code 0 \
                        --severity HIGH,CRITICAL \
                        --output trivy-fs-report.txt \
                        .
                """
            }
            post {
                always {
                    archiveArtifacts artifacts: 'trivy-fs-report.txt', allowEmptyArchive: true
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonar-server') {
                    sh """
                        ${SONAR_HOME}/bin/sonar-scanner \
                            -Dsonar.projectName=${params.APP_NAME} \
                            -Dsonar.projectKey=${params.SONAR_PROJECT_KEY} \
                            -Dsonar.sources=. \
                            -Dsonar.login=${SONAR_TOKEN}
                    """
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Docker Build') {
            steps {
                sh "docker build -t ${params.DOCKER_IMAGE_NAME}:${DOCKER_TAG} ."
                sh "docker tag ${params.DOCKER_IMAGE_NAME}:${DOCKER_TAG} ${params.DOCKER_IMAGE_NAME}:latest"
            }
        }

        stage('Trivy Image Scan') {
            steps {
                sh """
                    trivy image \
                        --format table \
                        --exit-code 0 \
                        --severity HIGH,CRITICAL \
                        --output trivy-image-report.txt \
                        ${params.DOCKER_IMAGE_NAME}:${DOCKER_TAG}
                """
            }
            post {
                always {
                    archiveArtifacts artifacts: 'trivy-image-report.txt', allowEmptyArchive: true
                }
            }
        }

        stage('Push to Docker Hub') {
            steps {
                withDockerRegistry(credentialsId: "${DOCKER_CREDENTIALS_ID}", url: 'https://index.docker.io/v1/') {
                    sh "docker push ${params.DOCKER_IMAGE_NAME}:${DOCKER_TAG}"
                    sh "docker push ${params.DOCKER_IMAGE_NAME}:latest"
                }
            }
        }

        stage('Deployment Strategy') {
            steps {
                script {
                    def userInput = input(
                        id: 'DeployStrategy',
                        message: 'Choose deployment strategy for ' + params.APP_NAME + ':' + DOCKER_TAG,
                        ok: 'Proceed',
                        parameters: [
                            choice(
                                name: 'STRATEGY',
                                choices: ['Continuous Deployment', 'Continuous Delivery'],
                                description: 'Continuous Deployment = auto deploy | Continuous Delivery = manual approval required'
                            )
                        ]
                    )
                    env.DEPLOY_STRATEGY = userInput
                }
            }
        }

        stage('Confirm Deployment') {
            when {
                expression { env.DEPLOY_STRATEGY == 'Continuous Delivery' }
            }
            steps {
                script {
                    def approver = input(
                        id: 'ApprovalGate',
                        message: 'Approve deployment of ' + params.DOCKER_IMAGE_NAME + ':' + DOCKER_TAG + ' to namespace ' + params.K8S_NAMESPACE + '?',
                        ok: 'Deploy Now',
                        submitter: 'devops-team,release-manager',
                        parameters: [
                            string(
                                name: 'APPROVAL_NOTES',
                                defaultValue: '',
                                description: 'Release notes or ticket reference'
                            )
                        ]
                    )
                    echo "Approved — Notes: ${approver.APPROVAL_NOTES}"
                }
            }
        }

        stage('Deploy to K8s Cluster') {
            steps {
                sh """
                    sed -i 's|IMAGE_PLACEHOLDER|${params.DOCKER_IMAGE_NAME}:${DOCKER_TAG}|g' ${K8S_DEPLOYMENT_FILE}
                    sed -i 's|NAMESPACE_PLACEHOLDER|${params.K8S_NAMESPACE}|g' ${K8S_DEPLOYMENT_FILE}
                    sed -i 's|APP_NAME_PLACEHOLDER|${params.APP_NAME}|g' ${K8S_DEPLOYMENT_FILE}

                    kubectl apply -f ${K8S_DEPLOYMENT_FILE} \
                        --server=${params.K8S_API_SERVER} \
                        --token=${K8S_SA_TOKEN} \
                        --insecure-skip-tls-verify=true \
                        -n ${params.K8S_NAMESPACE}

                    kubectl rollout status deployment/${params.APP_NAME}-deployment \
                        --server=${params.K8S_API_SERVER} \
                        --token=${K8S_SA_TOKEN} \
                        --insecure-skip-tls-verify=true \
                        -n ${params.K8S_NAMESPACE} \
                        --timeout=120s
                """
            }
        }

        stage('Verify Deployment') {
            steps {
                sh """
                    kubectl get pods \
                        --server=${params.K8S_API_SERVER} \
                        --token=${K8S_SA_TOKEN} \
                        --insecure-skip-tls-verify=true \
                        -n ${params.K8S_NAMESPACE} \
                        -l app=${params.APP_NAME}

                    kubectl get svc \
                        --server=${params.K8S_API_SERVER} \
                        --token=${K8S_SA_TOKEN} \
                        --insecure-skip-tls-verify=true \
                        -n ${params.K8S_NAMESPACE} \
                        -l app=${params.APP_NAME}
                """
            }
        }
    }

    post {
        success {
            emailext (
                subject: "SUCCESS: ${params.APP_NAME} Build #${BUILD_NUMBER} deployed to ${params.K8S_NAMESPACE}",
                body: """
Build:     #${BUILD_NUMBER}
App:       ${params.APP_NAME}
Image:     ${params.DOCKER_IMAGE_NAME}:${DOCKER_TAG}
Branch:    ${params.GIT_BRANCH}
Namespace: ${params.K8S_NAMESPACE}
Strategy:  ${env.DEPLOY_STRATEGY}
URL:       ${BUILD_URL}
                """,
                to: "${params.RECIPIENT_EMAIL}"
            )
        }
        failure {
            emailext (
                subject: "FAILED: ${params.APP_NAME} Build #${BUILD_NUMBER}",
                body: """
Build #${BUILD_NUMBER} failed.
App:    ${params.APP_NAME}
Branch: ${params.GIT_BRANCH}
Check:  ${BUILD_URL}
                """,
                to: "${params.RECIPIENT_EMAIL}"
            )
        }
        always {
            sh "docker rmi ${params.DOCKER_IMAGE_NAME}:${DOCKER_TAG} || true"
            cleanWs()
        }
    }
}
